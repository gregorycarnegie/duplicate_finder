{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Duplicate Finder",
  "version": "0.5.0",
  "identifier": "com.gregorycarnegie.duplicatefinder",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Duplicate Finder",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 560,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
